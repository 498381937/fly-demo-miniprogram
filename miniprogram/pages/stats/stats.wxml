<view class="page">
  <wxs src="../../utils/tools.wxs" module="tools" />

  <!-- 管理员切换：仅管理员可见 -->
  <view class="scope-bar" wx:if="{{isAdmin}}">
    <view
      class="scope-item {{scope === 'mine' ? 'active' : ''}}"
      data-scope="mine"
      bindtap="onScopeChange"
    >仅我的</view>
    <view
      class="scope-item {{scope === 'all' ? 'active' : ''}}"
      data-scope="all"
      bindtap="onScopeChange"
    >全部用户</view>
    <view class="scope-badge">👑 管理员</view>
  </view>

  <view class="summary" wx:if="{{stats}}">
    <view class="sm-card">
      <view class="sm-num">{{stats.totalFlights}}</view>
      <view class="sm-label">累计飞行架次</view>
    </view>
    <view class="sm-card">
      <view class="sm-num">{{tools.hours(stats.totalDurationSeconds)}}</view>
      <view class="sm-label">累计时长(h)</view>
    </view>
  </view>

  <view class="card" wx:if="{{stats && stats.daily}}">
    <view class="section-title">近 5 天飞行次数</view>
    <view class="bar-chart">
      <view
        wx:for="{{stats.daily}}"
        wx:key="date"
        class="bar-col"
      >
        <view class="bar-value">{{item.count}}</view>
        <view
          class="bar"
          style="height:{{item.count / maxDaily * 200 + 2}}rpx;"
        />
        <view class="bar-label">{{item.date}}</view>
      </view>
    </view>
  </view>

  <view class="card" wx:if="{{stats && stats.modelDistribution.length > 0}}">
    <view class="section-title">按机型分布</view>
    <view
      wx:for="{{stats.modelDistribution}}"
      wx:key="_id"
      class="dist-row"
    >
      <view class="dist-name">{{item._id || '未填写'}}</view>
      <view class="dist-bar-wrap">
        <view
          class="dist-bar"
          style="width:{{item.count / stats.totalFlights * 100}}%;"
        />
      </view>
      <view class="dist-count">{{item.count}} 次 / {{tools.hours(item.duration)}}h</view>
    </view>
  </view>

  <view class="card" wx:if="{{stats && stats.missionDistribution.length > 0}}">
    <view class="section-title">按任务类型分布</view>
    <view
      wx:for="{{stats.missionDistribution}}"
      wx:key="_id"
      class="dist-row"
    >
      <view class="dist-name">{{item._id || '未填写'}}</view>
      <view class="dist-bar-wrap">
        <view
          class="dist-bar mission"
          style="width:{{item.count / stats.totalFlights * 100}}%;"
        />
      </view>
      <view class="dist-count">{{item.count}} 次</view>
    </view>
  </view>

  <t-empty
    wx:if="{{stats && stats.totalFlights === 0 && !loading}}"
    description="暂无统计数据"
  />
</view>
