.page {
  padding: 24rpx;
  padding-bottom: 200rpx;
  box-sizing: border-box;
}

.head {
  background: linear-gradient(135deg, #0052d9 0%, #4a90ff 100%);
  border-radius: 16rpx;
  padding: 32rpx;
  color: #fff;
  margin-bottom: 16rpx;
}

.head-code {
  font-size: 36rpx;
  font-weight: 700;
}

.head-sub {
  opacity: .9;
  font-size: 26rpx;
  margin-top: 8rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, .04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #0052d9;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  width: 8rpx;
  height: 28rpx;
  background: #0052d9;
  margin-right: 12rpx;
  border-radius: 4rpx;
}

.row {
  display: flex;
  align-items: flex-start;
  padding: 14rpx 0;
  font-size: 28rpx;
}

.row .k {
  width: 180rpx;
  color: #888;
  flex-shrink: 0;
}

.row .v {
  flex: 1;
  color: #333;
  word-break: break-all;
}

.row .v.primary {
  color: #0052d9;
  font-weight: 600;
}

.block {
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.block:last-child {
  border-bottom: 0;
}

.b-title {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 8rpx;
}

.b-body {
  font-size: 28rpx;
  color: #333;
  white-space: pre-wrap;
}

.b-body.danger {
  color: #e34d59;
  font-weight: 600;
}

.sign {
  width: 100%;
  height: 200rpx;
  background: #f7f9fc;
  border-radius: 12rpx;
}

.btn-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, .05);
}

.btn-bar t-button {
  flex: 1;
}

.bottom-spacer {
  height: 40rpx;
}

/* 任务评价 */
.rate-tip {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.rate-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.rate-row:last-of-type {
  border-bottom: 0;
}

.rate-label {
  font-size: 28rpx;
  color: #333;
  width: 160rpx;
  flex-shrink: 0;
}

.rate-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  justify-content: flex-end;
}

.rate-score {
  font-size: 26rpx;
  color: #0052d9;
  font-weight: 600;
  min-width: 72rpx;
  text-align: right;
  flex-shrink: 0;
}

.rate-tips {
  font-size: 24rpx;
  color: #aaa;
  padding: 4rpx 0 12rpx;
  line-height: 1.6;
}

.b-empty {
  color: #bbb;
}
