<view class="page" wx:if="{{detail}}">
  <view class="head">
    <view class="head-code">{{detail.logCode}}</view>
    <view class="head-sub">{{detail.flightDate}} · {{detail.totalDuration}}</view>
  </view>

  <view class="card">
    <view class="section-title">基础信息</view>
    <view class="row"><text class="k">飞行日期</text><text class="v">{{detail.flightDate}}</text></view>
    <view class="row"><text class="k">起飞时间</text><text class="v">{{detail.takeoffTime}}</text></view>
    <view class="row"><text class="k">降落时间</text><text class="v">{{detail.landingTime}}</text></view>
    <view class="row"><text class="k">总飞行时长</text><text class="v primary">{{detail.totalDuration}}</text></view>
    <view class="row"><text class="k">驾驶员</text><text class="v">{{detail.pilotName}}</text></view>
    <view class="row"><text class="k">学号/执照</text><text class="v">{{detail.pilotId}}</text></view>
    <view class="row"><text class="k">班级/单位</text><text class="v">{{detail.className}}</text></view>
    <view class="row"><text class="k">指导教师</text><text class="v">{{detail.teacher || '-'}}</text></view>
    <view class="row"><text class="k">无人机型号</text><text class="v">{{detail.droneModel}}</text></view>
    <view class="row"><text class="k">机身SN</text><text class="v">{{detail.bodySn}}</text></view>
    <view class="row"><text class="k">电池SN</text><text class="v">{{detail.batterySn}}</text></view>
    <view class="row"><text class="k">任务类型</text><text class="v">{{detail.missionType}}</text></view>
    <view class="row"><text class="k">起飞地点</text><text class="v">{{detail.takeoffLocation}}</text></view>
    <view class="row"><text class="k">降落地点</text><text class="v">{{detail.landingLocation}}</text></view>
    <view class="row"><text class="k">空域报备</text><text class="v">{{detail.airspaceCode}}</text></view>
  </view>

  <view class="card">
    <view class="section-title">飞行数据</view>
    <view class="row"><text class="k">最大高度</text><text class="v">{{detail.maxAltitude}} 米</text></view>
    <view class="row"><text class="k">最大水平速度</text><text class="v">{{detail.maxHorizontalSpeed}} m/s</text></view>
    <view class="row"><text class="k">最大垂直速度</text><text class="v">{{detail.maxVerticalSpeed}} m/s</text></view>
    <view class="row"><text class="k">起飞电量</text><text class="v">{{detail.takeoffSoc}} %</text></view>
    <view class="row"><text class="k">降落电量</text><text class="v">{{detail.landingSoc}} %</text></view>
    <view class="row"><text class="k">飞行模式</text><text class="v">{{detail.flightMode}}</text></view>
    <view class="row"><text class="k">悬停精度</text><text class="v">{{detail.hoverAccuracy || '-'}}</text></view>
    <view class="row"><text class="k">天气情况</text><text class="v">{{detail.weather}}</text></view>
  </view>

  <view class="card">
    <view class="section-title">异常与备注</view>
    <view class="block">
      <view class="b-title">告警/故障记录</view>
      <view class="b-body">{{detail.warningLog}}</view>
    </view>
    <view class="block">
      <view class="b-title">应急操作记录</view>
      <view class="b-body">{{detail.emergencyLog}}</view>
    </view>
    <view class="block">
      <view class="b-title">飞行前检查</view>
      <view class="b-body {{detail.preCheckResult === '不合格' ? 'danger' : ''}}">{{detail.preCheckResult}}</view>
    </view>
    <view class="block" wx:if="{{detail.teacherComment}}">
      <view class="b-title">教师评语/飞行总结</view>
      <view class="b-body">{{detail.teacherComment}}</view>
    </view>
    <view class="block" wx:if="{{detail.signatureImage}}">
      <view class="b-title">记录人签名</view>
      <image class="sign" src="{{detail.signatureImage}}" mode="aspectFit" />
    </view>
  </view>

  <view class="bottom-spacer" />

  <view class="btn-bar">
    <t-button theme="danger" variant="outline" bindtap="onDelete">删除</t-button>
    <t-button theme="primary" bindtap="onEdit">编辑</t-button>
  </view>
</view>
<t-empty wx:elif="{{!loading}}" description="日志不存在" />
