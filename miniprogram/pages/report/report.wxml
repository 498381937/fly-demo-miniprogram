<!-- pages/report/report.wxml -->
<view class="page">
  <t-tabs defaultValue="{{activeTab}}" value="{{activeTab}}" bindchange="onTabsChange" theme="card">
    <t-tab-panel label="基础信息" value="{{0}}">
      <view class="container">
        <view class="card">
          <view class="section-title">基础信息（必填项标*）</view>
          <view class="form-row">
            <view class="form-label">日志编号</view>
            <view class="form-value primary-color">{{logCode || '生成中...'}}</view>
          </view>
          <view class="form-row">
            <view class="form-label">
              <text class="required">*</text>
              飞行日期
            </view>
            <view class="form-value">
              <picker mode="date" value="{{flightDate}}" bindchange="onDateChange">
                <view class="{{flightDate ? '' : 'placeholder-gray'}}">
                  {{flightDate || '请选择飞行日期'}}
                </view>
              </picker>
            </view>
          </view>
          <view wx:if="{{errors.flightDate}}" class="text-error">{{errors.flightDate}}</view>
          <view class="form-row">
            <view class="form-label">
              <text class="required">*</text>
              起飞时间
            </view>
            <view class="form-value">
              <picker mode="time" value="{{takeoffTime}}" bindchange="onTakeoffTimeChange">
                <view class="{{takeoffTime ? '' : 'placeholder-gray'}}">
                  {{takeoffTime || '请选择起飞时间'}}
                </view>
              </picker>
            </view>
          </view>
          <view wx:if="{{errors.takeoffTime}}" class="text-error">{{errors.takeoffTime}}</view>
          <view class="form-row">
            <view class="form-label">
              <text class="required">*</text>
              降落时间
            </view>
            <view class="form-value">
              <picker mode="time" value="{{landingTime}}" bindchange="onLandingTimeChange">
                <view class="{{landingTime ? '' : 'placeholder-gray'}}">
                  {{landingTime || '请选择降落时间'}}
                </view>
              </picker>
            </view>
          </view>
          <view wx:if="{{errors.landingTime}}" class="text-error">{{errors.landingTime}}</view>
          <view class="form-row">
            <view class="form-label">
              <text class="required">*</text>
              总飞行时长
            </view>
            <view class="form-value primary-color">{{totalDuration || '自动计算'}}</view>
          </view>
          <view class="form-row">
            <view class="form-label">
              <text class="required">*</text>
              驾驶员姓名
            </view>
            <view class="form-value">
              <input class="input" placeholder="请输入学生/飞行员姓名" value="{{pilotName}}" data-field="pilotName" bindinput="onInput" />
            </view>
          </view>
          <view wx:if="{{errors.pilotName}}" class="text-error">{{errors.pilotName}}</view>
          <view class="form-row">
            <view class="form-label">
              <text class="required">*</text>
              学号/执照编号
            </view>
            <view class="form-value">
              <input class="input" placeholder="学生填学号，持证者填执照号" value="{{pilotId}}" data-field="pilotId" bindinput="onInput" />
            </view>
          </view>
          <view wx:if="{{errors.pilotId}}" class="text-error">{{errors.pilotId}}</view>
          <view class="form-row">
            <view class="form-label">
              <text class="required">*</text>
              班级/所属单位
            </view>
            <view class="form-value">
              <input class="input" placeholder="如：无人机22级1班" value="{{className}}" data-field="className" bindinput="onInput" />
            </view>
          </view>
          <view wx:if="{{errors.className}}" class="text-error">{{errors.className}}</view>
          <view class="form-row">
            <view class="form-label">
              <text class="required">*</text>
              指导教师
            </view>
            <view class="form-value">
              <picker mode="selector" range="{{instructorList}}" range-key="realName" value="{{teacherIndex}}" bindchange="onTeacherPick" disabled="{{instructorList.length === 0}}">
                <view class="{{teacher ? '' : 'placeholder-gray'}}">
                  {{teacher || (instructorList.length === 0 ? '暂无教师（请先完成注册）' : '请选择指导教师')}} ▼
                </view>
              </picker>
            </view>
          </view>
          <view wx:if="{{errors.teacher}}" class="text-error">{{errors.teacher}}</view>
          <view class="form-row">
            <view class="form-label">
              <text class="required">*</text>
              安全员
            </view>
            <view class="form-value">
              <picker mode="selector" range="{{personnelList}}" range-key="realName" value="{{safetyOfficerIndex}}" bindchange="onSafetyOfficerPick" disabled="{{personnelList.length === 0}}">
                <view class="{{safetyOfficer ? '' : 'placeholder-gray'}}">
                  {{safetyOfficer || (personnelList.length === 0 ? '暂无人员（请先完成注册）' : '请选择安全员')}} ▼
                </view>
              </picker>
            </view>
          </view>
          <view wx:if="{{errors.safetyOfficer}}" class="text-error">{{errors.safetyOfficer}}</view>
          <view class="form-row">
            <view class="form-label">
              <text class="required">*</text>
              无人机型号
            </view>
            <view class="form-value">
              <picker mode="selector" range="{{droneModels}}" value="{{droneModelIndex}}" bindchange="onDroneModelPick">
                <view class="{{droneModel ? '' : 'placeholder-gray'}}">
                  {{droneModel || '请选择无人机型号'}} ▼
                </view>
              </picker>
            </view>
          </view>
          <view wx:if="{{errors.droneModel}}" class="text-error">{{errors.droneModel}}</view>
          <view class="form-row">
            <view class="form-label">
              <text class="required">*</text>
              任务类型
            </view>
            <view class="form-value">
              <picker mode="selector" range="{{missionTypes}}" value="{{missionTypeIndex}}" bindchange="onMissionTypePick">
                <view class="{{missionType ? '' : 'placeholder-gray'}}">
                  {{missionType || '请选择飞行任务类型'}} ▼
                </view>
              </picker>
            </view>
          </view>
          <view wx:if="{{errors.missionType}}" class="text-error">{{errors.missionType}}</view>
          <view class="form-row">
            <view class="form-label">
              <text class="required">*</text>
              飞行模式
            </view>
            <view class="form-value">
              <picker mode="selector" range="{{flightModes}}" value="{{flightModeIndex}}" bindchange="onFlightModePick">
                <view class="{{flightMode ? '' : 'placeholder-gray'}}">
                  {{flightMode || '请选择飞行模式'}} ▼
                </view>
              </picker>
            </view>
          </view>
          <view wx:if="{{errors.flightMode}}" class="text-error">{{errors.flightMode}}</view>
          <view class="form-row">
            <view class="form-label">
              <text class="required">*</text>
              空域报备
            </view>
            <view class="form-value">
              <picker mode="selector" range="{{airspaceCodes}}" value="{{airspaceCodeIndex}}" bindchange="onAirspaceCodePick">
                <view class="{{airspaceCode ? '' : 'placeholder-gray'}}">
                  {{airspaceCode || '请选择空域报备'}} ▼
                </view>
              </picker>
            </view>
          </view>
          <view wx:if="{{errors.airspaceCode}}" class="text-error">{{errors.airspaceCode}}</view>
        </view>
      </view>
    </t-tab-panel>
    <t-tab-panel label="任务评价" value="{{1}}">
      <view class="container">
        <view class="card">
          <view class="section-title">任务评价</view>
          <view class="rate-tip">请对本次飞行任务各维度进行评分（1～5分）</view>
          <!-- 起降 -->
          <view class="rate-row">
            <view class="rate-label">
              <text class="required">*</text>
              起降
            </view>
            <view class="rate-right">
              <t-rate value="{{ratingTakeoffLanding}}" count="{{5}}" size="40rpx" showText="{{true}}" data-field="ratingTakeoffLanding" bindchange="onRatingChange" />
            </view>
          </view>
          <view class="rate-tips">起降要垂直均匀，在指定地点范围内</view>
          <view wx:if="{{errors.ratingTakeoffLanding}}" class="text-error">
            {{errors.ratingTakeoffLanding}}
          </view>
          <!-- 范围漂移 -->
          <view class="rate-row">
            <view class="rate-label">
              <text class="required">*</text>
              范围漂移
            </view>
            <view class="rate-right">
              <t-rate value="{{ratingDriftRange}}" count="{{5}}" size="40rpx" showText="{{true}}" data-field="ratingDriftRange" bindchange="onRatingChange" />
            </view>
          </view>
          <view class="rate-tips">范围不能漂移指定航线 0.2 米半径外</view>
          <view wx:if="{{errors.ratingDriftRange}}" class="text-error">
            {{errors.ratingDriftRange}}
          </view>
          <!-- 高度漂移 -->
          <view class="rate-row">
            <view class="rate-label">
              <text class="required">*</text>
              高度漂移
            </view>
            <view class="rate-right">
              <t-rate value="{{ratingDriftAltitude}}" count="{{5}}" size="40rpx" showText="{{true}}" data-field="ratingDriftAltitude" bindchange="onRatingChange" />
            </view>
          </view>
          <view class="rate-tips">高度不能漂移超过指定高度 ±0.2 米（GPS、定高模式下完全不能掉高）</view>
          <view wx:if="{{errors.ratingDriftAltitude}}" class="text-error">
            {{errors.ratingDriftAltitude}}
          </view>
          <!-- 航线完整：仅航线类任务（第5个及之后）显示 -->
          <block wx:if="{{missionTypeIndex !== null && missionTypeIndex >= 4}}">
            <view class="rate-row">
              <view class="rate-label">
                <text class="required">*</text>
                航线完整
              </view>
              <view class="rate-right">
                <t-rate value="{{ratingRouteIntegrity}}" count="{{5}}" size="40rpx" showText="{{true}}" data-field="ratingRouteIntegrity" bindchange="onRatingChange" />
              </view>
            </view>
            <view class="rate-tips">是否完全飞完航线</view>
            <view wx:if="{{errors.ratingRouteIntegrity}}" class="text-error">
              {{errors.ratingRouteIntegrity}}
            </view>
          </block>
        </view>
      </view>
    </t-tab-panel>
    <t-tab-panel label="异常与备注" value="{{2}}">
      <view class="container">
        <view class="card">
          <view class="section-title">异常与备注</view>
          <view class="multiline-label mt20">教师评语/飞行总结</view>
          <textarea class="textarea" placeholder="默认无，填写操作评价与建议" value="{{teacherComment}}" data-field="teacherComment" bindinput="onInput" maxlength="500" auto-height />
          <view class="multiline-label mt20">
            <text class="required">*</text>
            记录人电子签名
          </view>
          <view class="signature-box" bindtap="openSignature">
            <image wx:if="{{signatureImage}}" src="{{signatureImage}}" mode="aspectFit" class="signature-img" />
            <view wx:else class="signature-placeholder">
              <t-icon name="edit" size="48rpx" color="#0052d9" />
              <text>点击此处手写签名</text>
            </view>
          </view>
          <view class="signature-actions" wx:if="{{signatureImage}}">
            <view class="link" bindtap="clearSignature">清除签名</view>
            <view class="link" bindtap="openSignature">重新签名</view>
          </view>
        </view>
      </view>
    </t-tab-panel>
  </t-tabs>
  <view class="bottom-spacer" />
  <view class="btn-bar">
    <t-button theme="default" bindtap="onReset">重置</t-button>
    <t-button theme="primary" loading="{{submitting}}" bindtap="onSubmit">
      {{editId ? '保存修改' : '提交日志'}}
    </t-button>
  </view>
</view>