/* pages/timer/timer.wxss */

.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #e8f0fe 0%, #f5f5f5 60%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 32rpx 120rpx;
  box-sizing: border-box;
}

/* 顶部标题 */
.header {
  width: 100%;
  text-align: center;
  margin-bottom: 40rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #0052d9;
  letter-spacing: 4rpx;
}

.header-sub {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
  line-height: 1.5;
}

/* 计时卡片 */
.timer-card {
  width: 100%;
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 82, 217, .10);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 状态徽章 */
.status-badge {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 28rpx;
  border-radius: 100rpx;
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 40rpx;
}

.status-idle {
  background: #f2f2f2;
  color: #999;
}

.status-running {
  background: #e8f5e9;
  color: #2e7d32;
}

.status-done {
  background: #e3f2fd;
  color: #0052d9;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #bbb;
}

.status-dot--blink {
  background: #43a047;
  animation: blink 1s infinite;
}

.status-dot--done {
  background: #0052d9;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: .3; }
}

/* 大时钟 */
.clock-face {
  margin: 16rpx 0 48rpx;
}

.clock-text {
  font-size: 120rpx;
  font-weight: 700;
  color: #1a1a2e;
  letter-spacing: 6rpx;
  font-variant-numeric: tabular-nums;
}

/* 时间信息区 */
.time-info {
  display: flex;
  align-items: center;
  width: 100%;
  margin-bottom: 32rpx;
}

.time-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.time-label {
  font-size: 24rpx;
  color: #999;
}

.time-value {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.time-value--empty {
  color: #ccc;
}

.time-divider {
  width: 2rpx;
  height: 60rpx;
  background: #e8e8e8;
}

/* 日期行 */
.date-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: #f0f5ff;
  border-radius: 16rpx;
  padding: 14rpx 28rpx;
}

.date-text {
  font-size: 28rpx;
  color: #0052d9;
  font-weight: 500;
}

/* 操作区 */
.action-area {
  width: 100%;
  margin-top: 56rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 开始按钮 */
.btn-start {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  background: linear-gradient(135deg, #0052d9 0%, #4e9af1 100%);
  border-radius: 50%;
  width: 240rpx;
  height: 240rpx;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(0, 82, 217, .35);
  active-background-color: rgba(0, 0, 0, .1);
}

.btn-start:active {
  transform: scale(.96);
}

/* 停止按钮 */
.btn-stop {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  background: linear-gradient(135deg, #e53935 0%, #ef9a9a 100%);
  border-radius: 50%;
  width: 240rpx;
  height: 240rpx;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(229, 57, 53, .35);
}

.btn-stop:active {
  transform: scale(.96);
}

.btn-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

/* 完成状态按钮组 */
.btn-group {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  align-items: center;
}

.btn-fill {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: linear-gradient(135deg, #0052d9 0%, #4e9af1 100%);
  border-radius: 100rpx;
  padding: 28rpx 60rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 82, 217, .30);
}

.btn-fill:active {
  transform: scale(.97);
}

.btn-fill-text {
  font-size: 34rpx;
  color: #fff;
  font-weight: 700;
}

.btn-reset {
  display: flex;
  align-items: center;
  gap: 10rpx;
  border: 2rpx solid #0052d9;
  border-radius: 100rpx;
  padding: 20rpx 48rpx;
}

.btn-reset:active {
  opacity: .7;
}

.btn-reset-text {
  font-size: 28rpx;
  color: #0052d9;
  font-weight: 500;
}

/* 跳过链接 */
.skip-row {
  margin-top: 48rpx;
}

.skip-link {
  font-size: 26rpx;
  color: #0052d9;
  opacity: .7;
}
