<!-- pages/profile/profile.wxml -->
<view class="page">
  <view class="user-card">
    <!-- 头像区 -->
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar" hover-class="none">
      <image class="avatar" src="{{userInfo.avatarUrl || defaultAvatar}}" mode="aspectFill" />
    </button>
    <!-- 信息区 -->
    <view class="user-info">
      <block wx:if="{{!editingNickname}}">
        <view class="nickname-text {{userInfo.nickName ? '' : 'nickname-empty'}}" bindtap="startEditNickname">
          <text class="nickname-label">{{userInfo.nickName || '点击输入微信昵称'}}</text>
          <text wx:if="{{isAdmin}}" class="admin-badge">管理员</text>
        </view>
      </block>
      <block wx:else>
        <input class="nickname-input" type="nickname" placeholder-class="ph-white" value="{{userInfo.nickName}}" focus="{{nicknameFocus}}" confirm-type="done" bindinput="onNicknameInput" bindblur="onNicknameBlur" bindconfirm="onNicknameBlur" />
      </block>
      <view class="user-sub">
        {{registered ? roleOptions[roleIndex] : '未注册'}}
        <text wx:if="{{isAdmin}}" class="admin-inline"> · 管理员</text>
      </view>
      <view wx:if="{{openid}}" class="openid-row" bindtap="copyOpenid">
        <text class="openid-label">OpenID：</text>
        <text class="openid-value">{{openid}}</text>
        <text class="openid-copy">复制</text>
      </view>
    </view>
  </view>

  <!-- 一键操作 -->
  <view class="quick-actions">
    <view wx:if="{{userInfo.avatarUrl || userInfo.nickName}}" class="qa-btn danger" bindtap="clearUserInfo">
      <text>🗑️</text>
      <text>清除头像与昵称</text>
    </view>
  </view>

  <!-- 身份注册卡片 -->
  <view class="card">
    <view class="section-title">
      身份注册
      <text wx:if="{{registered}}" class="registered-tag">已注册</text>
      <text wx:else class="unregistered-tag">未注册</text>
    </view>

    <!-- 提示文案 -->
    <view class="reg-tip">
      <text wx:if="{{registered && !editing}}">以下为您已登记的身份信息，点击「更新信息」可修改。</text>
      <text wx:elif="{{registered && editing}}">正在编辑身份信息，修改完成后点击「保存信息」。</text>
      <text wx:else>请选择您的身份并填写信息，完成注册后系统将自动预填飞行日志。</text>
    </view>

    <!-- 用户身份 -->
    <view class="form-row">
      <view class="form-label"><text wx:if="{{editing}}" class="required">*</text>用户身份</view>
      <view class="form-value">
        <!-- 编辑态：picker 可选 -->
        <block wx:if="{{editing}}">
          <picker mode="selector" range="{{roleOptions}}" value="{{roleIndex}}" bindchange="onRolePick">
            <view class="picker-value">{{roleOptions[roleIndex]}} ▼</view>
          </picker>
        </block>
        <!-- 只读态：纯文本 -->
        <block wx:else>
          <view class="readonly-value">{{roleOptions[roleIndex]}}</view>
        </block>
      </view>
    </view>

    <!-- 姓名 -->
    <view class="form-row">
      <view class="form-label"><text wx:if="{{editing}}" class="required">*</text>姓名</view>
      <view class="form-value">
        <input wx:if="{{editing}}" class="input" placeholder="请输入真实姓名" value="{{reg.realName}}" data-field="realName" bindinput="onRegInput" />
        <view wx:else class="readonly-value {{reg.realName ? '' : 'readonly-empty'}}">{{reg.realName || '未填写'}}</view>
      </view>
    </view>

    <!-- 学号/编号 -->
    <view class="form-row">
      <view class="form-label"><text wx:if="{{editing}}" class="required">*</text>{{idLabel}}</view>
      <view class="form-value">
        <input wx:if="{{editing}}" class="input" placeholder="请输入{{idLabel}}" value="{{reg.studentId}}" data-field="studentId" bindinput="onRegInput" />
        <view wx:else class="readonly-value {{reg.studentId ? '' : 'readonly-empty'}}">{{reg.studentId || '未填写'}}</view>
      </view>
    </view>

    <!-- 联系方式 -->
    <view class="form-row">
      <view class="form-label">联系方式</view>
      <view class="form-value">
        <input wx:if="{{editing}}" class="input" type="number" placeholder="手机号码（选填）" value="{{reg.phone}}" data-field="phone" bindinput="onRegInput" />
        <view wx:else class="readonly-value {{reg.phone ? '' : 'readonly-empty'}}">{{reg.phone || '未填写'}}</view>
      </view>
    </view>

    <!-- 班级/单位 -->
    <view class="form-row">
      <view class="form-label"><text wx:if="{{editing}}" class="required">*</text>班级/单位</view>
      <view class="form-value">
        <input wx:if="{{editing}}" class="input" placeholder="如：无人机22级1班" value="{{reg.className}}" data-field="className" bindinput="onRegInput" />
        <view wx:else class="readonly-value {{reg.className ? '' : 'readonly-empty'}}">{{reg.className || '未填写'}}</view>
      </view>
    </view>

    <!-- 按钮区 -->
    <!-- 未注册 或 已注册且编辑中：显示保存/完成注册按钮 -->
    <block wx:if="{{!registered || editing}}">
      <t-button class="save-button" theme="primary" block size="small" loading="{{saving}}" bindtap="saveProfile">
        {{registered ? '保存信息' : '完成注册'}}
      </t-button>
    </block>
    <!-- 已注册且只读：显示更新信息按钮 -->
    <block wx:else>
      <t-button class="save-button" theme="light" block size="small" bindtap="startEditing">
        更新信息
      </t-button>
    </block>
  </view>

  <!-- 其他操作 -->
  <view class="card">
    <view class="section-title">其他操作</view>
    <view class="menu-row" bindtap="goReport">
      <text>🚀 填报新日志</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-row" bindtap="goStats">
      <text>📊 查看数据统计</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-row" bindtap="clearDraft">
      <text>🗑️ 清除本地草稿 {{hasDraft ? '（有草稿）' : '（无）'}}</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="footer">多旋翼无人机飞行云日志系统 v1.0.0</view>
</view>
