.page {
  padding: 24rpx;
  box-sizing: border-box;
  min-height: 100vh;
}

.user-card {
  background: linear-gradient(135deg, #0052d9, #4a90ff);
  color: #fff;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 82, 217, .18);
}

/* 头像按钮：去掉微信 button 默认样式 */
.avatar-btn {
  background: transparent;
  padding: 0;
  margin: 0;
  line-height: 1;
  border: 0;
  width: 140rpx !important;
  height: 140rpx;
  flex-shrink: 0;
}

.avatar-btn::after {
  border: 0;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #d8d8d8;
}

.user-info {
  flex: 1;
  min-width: 0;
  /* flex item 文字省略必需 */
  overflow: hidden;
}

.nickname-text {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  max-width: 100%;
  overflow: hidden;
}

.nickname-label {
  font-size: 28rpx;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nickname-empty {
  font-weight: 400;
  opacity: .85;
}

.edit-icon {
  font-size: 28rpx;
  padding: 2rpx 10rpx;
  background: rgba(255, 255, 255, .2);
  border-radius: 20rpx;
  margin-left: 4rpx;
}

.admin-badge {
  flex-shrink: 0;
  font-size: 20rpx;
  color: #fff3cd;
  background: rgba(255, 215, 0, .25);
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  margin-left: 4rpx;
  border: 1rpx solid rgba(255, 215, 0, .5);
}

.openid-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 10rpx;
  font-size: 20rpx;
  color: rgba(255, 255, 255, .85);
  background: rgba(255, 255, 255, .1);
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
  max-width: 100%;
}

.openid-label {
  flex-shrink: 0;
}

.openid-value {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-family: 'SF Mono', Menlo, Consolas, monospace;
}

.openid-copy {
  flex-shrink: 0;
  padding: 0 10rpx;
  color: #fff;
  background: rgba(255, 255, 255, .2);
  border-radius: 12rpx;
}

.nickname-input {
  font-size: 28rpx;
  line-height: 24rpx;
  font-weight: 600;
  color: #fff;
  background: rgba(255, 255, 255, .15);
  border-radius: 8rpx;
  padding: 6rpx 16rpx;
  box-sizing: border-box;
  width: 100%;
}

.ph-white {
  color: rgba(255, 255, 255, .7);
}

.user-sub {
  font-size: 24rpx;
  opacity: .85;
  margin-top: 10rpx;
}

/* 一键操作按钮 */
.quick-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.qa-btn {
  flex: 1;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: #0052d9;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, .04);
}

.qa-btn.danger {
  color: #e34d59;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, .04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #0052d9;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  width: 8rpx;
  height: 28rpx;
  background: #0052d9;
  margin-right: 12rpx;
  border-radius: 4rpx;
}

.form-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-label {
  width: 180rpx;
  color: #333;
  font-size: 28rpx;
}

.form-value {
  flex: 1;
}

.input {
  font-size: 28rpx;
  width: 100%;
}

.menu-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 28rpx;
}

.menu-row__left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.approval-badge {
  display: inline-flex;
}

.menu-row:last-child {
  border-bottom: 0;
}

.arrow {
  color: #bbb;
  font-size: 32rpx;
}

.footer {
  text-align: center;
  color: #bbb;
  font-size: 22rpx;
  padding: 30rpx 0;
}

.save-button {
  margin-top: 24rpx;
}

/* ============ 注册审批状态标签 ============ */
.approval-pending-tag {
  font-size: 20rpx;
  color: #fa8c16;
  background: #fff7e6;
  border: 1rpx solid #ffd591;
  border-radius: 20rpx;
  padding: 4rpx 14rpx;
  margin-left: 12rpx;
}

.approval-rejected-tag {
  font-size: 20rpx;
  color: #ff4d4f;
  background: #fff2f0;
  border: 1rpx solid #ffccc7;
  border-radius: 20rpx;
  padding: 4rpx 14rpx;
  margin-left: 12rpx;
}

/* ============ 审批状态横幅 ============ */
.approval-banner {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin: 0 0 16rpx;
}

.approval-banner--pending {
  background: #fffbe6;
  border: 1rpx solid #ffe58f;
}

.approval-banner--rejected {
  background: #fff2f0;
  border: 1rpx solid #ffccc7;
}

.approval-banner__icon {
  font-size: 28rpx;
  flex-shrink: 0;
  line-height: 1.5;
}

.approval-banner__body {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.approval-banner__text {
  font-size: 26rpx;
  color: #d48806;
  line-height: 1.5;
}

.approval-banner--rejected .approval-banner__text {
  color: #cf1322;
}

.approval-banner__reason {
  font-size: 24rpx;
  color: #ff4d4f;
  line-height: 1.5;
}

/* 审批中入口高亮 */
.menu-row--approval {
  color: #0052d9;
  font-weight: 500;
}

/* 已注册 / 未注册 标签 */
.registered-tag {
  font-size: 20rpx;
  font-weight: 400;
  color: #fff;
  background: #00a870;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
}

.unregistered-tag {
  font-size: 20rpx;
  font-weight: 400;
  color: #fff;
  background: #e6a23c;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
}

/* 顶部用户角色行内文字 */
.admin-inline {
  font-size: 20rpx;
  color: #fff3cd;
}

/* 注册提示文案 */
.reg-tip {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
  line-height: 1.6;
}

/* 必填标记 */
.required {
  color: #e34d59;
  margin-right: 4rpx;
}

/* picker 显示值 */
.picker-value {
  font-size: 28rpx;
  color: #333;
}

/* 只读态显示值 */
.readonly-value {
  font-size: 28rpx;
  color: #333;
}

.readonly-empty {
  color: #bbb;
}

/* ============ 数据统计 ============ */
.stats-loading {
  font-size: 26rpx;
  color: #bbb;
  padding: 16rpx 0;
  text-align: center;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.stats-row:last-child {
  border-bottom: 0;
}

.stats-label {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 28rpx;
  color: #333;
}

.stats-icon {
  font-size: 30rpx;
}

.stats-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #0052d9;
}